# Workspace root
WORKSPACE_ROOT=/app/data/workspaces

# Fixed local workspace used to seed the built-in official Agent market item.
# Defaults to <home>/.openclaw/workspace when left empty.
OFFICIAL_AGENT_WORKSPACE=

# Required in production. Use a long random value.
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Server
PORT=3002
WS_PORT=3003
NODE_ENV=production

# Public backend URL used when the API generates absolute asset URLs.
# If port 80 does not proxy /api to the backend, use http://121.40.242.77:3002 instead.
PUBLIC_BACKEND_URL=http://121.40.242.77

# Public base URL used to generate Feishu event callback URLs.
# Prefer a domain + HTTPS later; for the current ECS public IP use the same public entry.
FEISHU_PUBLIC_BASE_URL=http://121.40.242.77

# CORS: set this to the public frontend origin. Multiple origins are comma-separated.
CORS_ORIGIN=http://121.40.242.77

# Coze cross-dimensional market
# Server-side token for calling Coze Chat API v3. Never expose this in frontend env.
COZE_API_BASE=https://api.coze.com
COZE_API_TOKEN=

# Optional JSON array. Each item:
# {"botId":"...","name":"...","description":"...","icon":"...","tags":["Coze"],"category":"Productivity","creator":"Coze","rating":4.8,"deployCount":12000,"sourceUrl":"https://www.coze.com/store/bot/..."}
COZE_MARKET_BOTS=[]
