    "smoke:workflow:project": "tsx src/scripts/smoke-workflow-project-handoff.ts",
    "smoke:windows-no-wsl": "tsx src/scripts/smoke-windows-no-wsl-runtime.ts",
    "smoke:http": "tsx src/scripts/smoke-http-project-upload.ts",
    "smoke:http:workflow": "tsx src/scripts/smoke-http-workflow-handoff.ts",
